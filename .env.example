# VantageNode-X — template de variáveis de ambiente.
# Copie para .env e preencha com valores reais. .env NUNCA é versionado.
# Segredos reais só vivem em .env (invariante de segurança do CLAUDE.md).

# --- API de dados VantageNode (Fase 2) ---
# Bloqueador conhecido: token depende do Gui; endpoint de MVRV tem bug aberto.
VANTAGENODE_API_BASE_URL=
VANTAGENODE_API_TOKEN=

# --- API do X / Twitter (Fase 4 — automação de publicação) ---
# Lembrete do invariante 9: a API do X é dependência frágil, não alicerce.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
